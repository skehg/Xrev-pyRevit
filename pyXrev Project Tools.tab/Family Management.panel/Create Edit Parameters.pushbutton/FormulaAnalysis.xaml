<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Formula Analysis"
        Width="860"
        Height="520"
        MinWidth="600"
        MinHeight="400"
        WindowStartupLocation="CenterOwner"
        Closed="on_close">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Padding" Value="10 4"/>
            <Setter Property="Background" Value="#F0F0F0"/>
            <Setter Property="BorderBrush" Value="#BDBDBD"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" MinHeight="60"/>
            <RowDefinition Height="6"/>
            <RowDefinition Height="110" MinHeight="50"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ── Row 0: Side-by-side formula panels ── -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <GroupBox Grid.Column="0" Header="Original" Padding="6">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <TextBlock x:Name="txtOriginalFormula"
                               FontFamily="Consolas"
                               FontSize="13"
                               TextWrapping="Wrap"
                               Margin="2"/>
                </ScrollViewer>
            </GroupBox>

            <GroupBox Grid.Column="2" Header="Suggested" Padding="6">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <TextBlock x:Name="txtSuggestedFormula"
                               FontFamily="Consolas"
                               FontSize="13"
                               TextWrapping="Wrap"
                               Margin="2"/>
                </ScrollViewer>
            </GroupBox>
        </Grid>

        <!-- ── Row 1: GridSplitter ── -->
        <GridSplitter Grid.Row="1"
                      Height="6"
                      HorizontalAlignment="Stretch"
                      ResizeDirection="Rows"
                      ResizeBehavior="PreviousAndNext"
                      Background="#E0E0E0"
                      Margin="0 1 0 1"
                      Cursor="SizeNS"/>

        <!-- ── Row 2: Suggestions panel ── -->
        <GroupBox Grid.Row="2" Header="Suggestions" Margin="0 0 0 0" Padding="4">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Nav row -->
                <Grid Grid.Row="0" Margin="0 0 0 4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" x:Name="btnPrevSuggestion"
                            Content="&lt;" Width="36"
                            FontWeight="Bold" FontSize="14"
                            Margin="0 0 2 0"
                            Click="on_prev_suggestion"
                            ToolTip="Previous suggestion"/>
                    <Button Grid.Column="1" x:Name="btnNextSuggestion"
                            Content="&gt;" Width="36"
                            FontWeight="Bold" FontSize="14"
                            Click="on_next_suggestion"
                            ToolTip="Next suggestion"/>
                    <TextBlock Grid.Column="2" x:Name="txtSuggestionCounter"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Left"
                               Margin="8 0 0 0"
                               Foreground="#888888"
                               FontSize="11"/>
                    <Button Grid.Column="3" x:Name="btnCopySuggestion"
                            Content="Copy" Width="60"
                            Click="on_copy_suggestion"
                            ToolTip="Copy suggestion text to clipboard"/>
                </Grid>

                <!-- Suggestion text -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <TextBlock x:Name="txtSuggestionText"
                               TextWrapping="Wrap"
                               FontSize="12"
                               Margin="0 0 0 2"/>
                </ScrollViewer>

                <!-- Create & Replace panel — only visible for repeated subexpression suggestions -->
                <Border Grid.Row="2" x:Name="pnlCreateReplace"
                        Visibility="Collapsed"
                        BorderBrush="#BDBDBD" BorderThickness="1"
                        Background="#F0F5FF"
                        Margin="0 4 0 0" Padding="6 4">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <!-- Row 0: parameter name + scope -->
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="New parameter:"
                                   VerticalAlignment="Center" Margin="0 0 6 0" FontSize="11"/>
                        <TextBox Grid.Row="0" Grid.Column="1" x:Name="txtNewParamName"
                                 VerticalAlignment="Center" FontSize="11" Height="24" Padding="3 2"/>
                        <RadioButton Grid.Row="0" Grid.Column="2" x:Name="rbNewParamInstance"
                                     Content="Instance" VerticalAlignment="Center"
                                     GroupName="NewParamScope"
                                     Margin="10 0 6 0" FontSize="11"/>
                        <RadioButton Grid.Row="0" Grid.Column="3" x:Name="rbNewParamType"
                                     Content="Type" VerticalAlignment="Center"
                                     GroupName="NewParamScope"
                                     Margin="0 0 10 0" FontSize="11" IsChecked="True"/>
                        <!-- Row 1: data type + action button -->
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Data type:"
                                   VerticalAlignment="Center" Margin="0 4 6 0" FontSize="11"/>
                        <ComboBox Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="3"
                                  x:Name="cmbNewDataType"
                                  DisplayMemberPath="Label"
                                  VerticalAlignment="Center"
                                  Height="24" FontSize="11"
                                  Margin="0 4 10 0"/>
                        <Button Grid.Row="1" Grid.Column="4" x:Name="btnCreateReplace"
                                Content="Create &amp; Replace" Width="130" Height="26"
                                Margin="0 4 0 0"
                                Click="on_create_and_replace"
                                ToolTip="Create a new parameter whose formula is this subexpression, then replace all occurrences in affected parameter formulas"/>
                    </Grid>
                </Border>
            </Grid>
        </GroupBox>

        <!-- ── Row 3: Metrics ── -->
        <TextBlock Grid.Row="3"
                   x:Name="txtMetrics"
                   Foreground="#5A5A5A"
                   FontSize="11"
                   Margin="0 6 0 0"/>

        <!-- ── Row 4: Buttons ── -->
        <StackPanel Grid.Row="4"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0 10 0 0">
            <Button x:Name="btnApply"
                    Content="Apply Suggestion"
                    Width="130"
                    Margin="0 0 8 0"
                    Click="on_apply"/>
            <Button x:Name="btnClose"
                    Content="Close"
                    Width="80"
                    Click="on_close"/>
        </StackPanel>
    </Grid>
</Window>
