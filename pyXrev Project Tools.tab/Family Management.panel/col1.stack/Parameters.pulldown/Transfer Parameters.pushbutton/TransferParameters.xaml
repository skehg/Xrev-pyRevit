<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Transfer Family Parameters"
        Height="680" Width="760"
        MinHeight="520" MinWidth="620"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize">

    <Window.Resources>

        <!-- Yellow row highlight for parameters that have formulas -->
        <Style x:Key="FormulaRowStyle" TargetType="ListViewItem">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsLikelyNonTransferable}" Value="True">
                    <Setter Property="Background" Value="#E3F2FD"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding HasFormula}" Value="True">
                    <Setter Property="Background" Value="#FFFDE7"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" MinHeight="200"/>   <!-- Parameter list -->
            <RowDefinition Height="6"/>                    <!-- Splitter -->
            <RowDefinition Height="160" MinHeight="100"/> <!-- Target families -->
            <RowDefinition Height="Auto"/>                 <!-- Footer -->
        </Grid.RowDefinitions>

        <TabControl Grid.Row="0" x:Name="transferTabs">

            <!-- ======================================================== -->
            <!-- TAB 1: PARAMETERS                                       -->
            <!-- ======================================================== -->
            <TabItem Header="Parameters">
                <Grid Margin="8 6 8 6">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>  <!-- Toolbar row -->
                        <RowDefinition Height="*"/>     <!-- List -->
                        <RowDefinition Height="Auto"/>  <!-- Global transfer options -->
                    </Grid.RowDefinitions>

                    <!-- Toolbar: filter + select buttons -->
                    <Grid Grid.Row="0" Margin="0 0 0 6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="220"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Search:"
                                   Grid.Column="0"
                                   VerticalAlignment="Center"
                                   Margin="0 0 6 0"/>
                        <TextBox x:Name="txtSearch"
                                 Grid.Column="1"
                                 Height="24"
                                 VerticalAlignment="Center"
                                 ToolTip="Search by parameter name or formula text"
                                 TextChanged="on_search_changed"/>

                        <CheckBox x:Name="chkHideFormulas"
                                  Content="Hide parameters with formulas"
                                  Grid.Column="3"
                                  VerticalAlignment="Center"
                                  Margin="0 0 12 0"
                                  Checked="on_filter_changed"
                                  Unchecked="on_filter_changed"/>

                        <TextBlock Grid.Column="4"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Right"
                                   Foreground="#336699"
                                   Margin="0 0 8 0"
                                   Text="Blue rows = likely system/non-transferable"/>

                        <!-- spacer -->
                        <StackPanel Grid.Column="5" Orientation="Horizontal">
                            <Button Content="Select All"
                                    Width="80" Height="26"
                                    Margin="0 0 5 0"
                                    Click="on_params_select_all"/>
                            <Button Content="Select None"
                                    Width="80" Height="26"
                                    Click="on_params_select_none"/>
                        </StackPanel>
                    </Grid>

                    <!-- Parameter ListView -->
                    <ListView x:Name="paramListView"
                              Grid.Row="1"
                              ItemContainerStyle="{StaticResource FormulaRowStyle}"
                              SelectionMode="Extended">
                        <ListView.View>
                            <GridView>

                                <!-- Checkbox column -->
                                <GridViewColumn Width="32">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay,
                                                      UpdateSourceTrigger=PropertyChanged}"
                                                      HorizontalAlignment="Center"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>

                                <!-- Name -->
                                <GridViewColumn Header="Name" Width="180"
                                                DisplayMemberBinding="{Binding Name}"/>

                                <!-- Group -->
                                <GridViewColumn Header="Group" Width="150"
                                                DisplayMemberBinding="{Binding GroupLabel}"/>

                                <!-- Instance / Type -->
                                <GridViewColumn Header="Inst / Type" Width="80"
                                                DisplayMemberBinding="{Binding InstanceTypeLabel}"/>

                                <!-- Shared -->
                                <GridViewColumn Header="Shared" Width="55"
                                                DisplayMemberBinding="{Binding SharedLabel}"/>

                                <!-- Formula -->
                                <GridViewColumn Header="Formula" Width="200"
                                                DisplayMemberBinding="{Binding Formula}"/>

                            </GridView>
                        </ListView.View>
                    </ListView>

                    <WrapPanel Grid.Row="2" Margin="0 8 0 0">
                        <CheckBox x:Name="chkCopyFormulas"
                                  Content="Transfer formulas"
                                  IsChecked="True"
                                  VerticalAlignment="Center"
                                  Margin="0 0 14 0"
                                  ToolTip="When unchecked, only parameters/values are transferred (no formulas)."/>

                        <CheckBox x:Name="chkCopyValues"
                                  Content="Transfer values"
                                  IsChecked="True"
                                  VerticalAlignment="Center"
                                  Margin="0 0 14 0"
                                  ToolTip="Copy parameter values after transfer."/>

                        <CheckBox x:Name="chkOverwriteValues"
                                  Content="Overwrite existing values"
                                  IsChecked="False"
                                  VerticalAlignment="Center"
                                  Margin="0 0 14 0"
                                  ToolTip="When checked, value copy can update parameters already existing in target families."/>

                        <CheckBox x:Name="chkCreateMissingMaterials"
                                  Content="Create new materials"
                                  IsChecked="False"
                                  VerticalAlignment="Center"
                                  ToolTip="When checked, missing materials in target families are created and material properties are copied from source."/>
                    </WrapPanel>
                </Grid>
            </TabItem>

            <!-- ======================================================== -->
            <!-- TAB 2: NESTED FAMILIES                                  -->
            <!-- ======================================================== -->
            <TabItem Header="Nested Families">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Margin="0 0 0 8"
                               TextWrapping="Wrap"
                               Text="Select nested families from the source family."/>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Select All"
                                Width="80" Height="24"
                                Margin="0 0 5 0"
                                Click="on_nested_select_all"/>
                        <Button Content="Select None"
                                Width="80" Height="24"
                                Click="on_nested_select_none"/>
                    </StackPanel>

                    <ListView x:Name="nestedFamilyListView" Grid.Row="1">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Width="32">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                      HorizontalAlignment="Center"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="Nested Family" Width="280"
                                                DisplayMemberBinding="{Binding Name}"/>
                                <GridViewColumn Header="Category" Width="180"
                                                DisplayMemberBinding="{Binding CategoryName}"/>
                                <GridViewColumn Header="Status" Width="180"
                                                DisplayMemberBinding="{Binding Status}"/>
                            </GridView>
                        </ListView.View>
                    </ListView>

                    <WrapPanel Grid.Row="2" Margin="0 8 0 0">
                        <CheckBox x:Name="chkNestedLoadMissingOnly"
                                  Content="Load missing only"
                                  IsChecked="True"
                                  Margin="0 0 14 0"/>
                        <CheckBox x:Name="chkNestedReloadExisting"
                                  Content="Reload existing"
                                  IsChecked="False"/>
                    </WrapPanel>
                </Grid>
            </TabItem>

            <!-- ======================================================== -->
            <!-- TAB 3: OBJECT STYLES                                     -->
            <!-- ======================================================== -->
            <TabItem Header="Object Styles">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0 0 0 8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="280"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   VerticalAlignment="Center"
                                   Margin="0 0 6 0"
                                   Text="Parent Category:"/>
                        <ComboBox x:Name="parentStyleCategoryCombo"
                                  Grid.Column="1"
                                  Height="24"
                                  SelectionChanged="on_parent_style_category_changed"
                                  ToolTip="Filter subcategories by parent category."/>

                        <TextBlock Grid.Column="2"
                                   VerticalAlignment="Center"
                                   Margin="10 0 0 0"
                                   Foreground="#666666"
                                   Text="System/hard-coded subcategories are hidden"/>

                        <Button Content="Select All"
                                Grid.Column="3"
                                Width="80" Height="24"
                                Margin="0 0 5 0"
                                Click="on_styles_select_all"/>
                        <Button Content="Select None"
                                Grid.Column="4"
                                Width="80" Height="24"
                                Click="on_styles_select_none"/>
                    </Grid>

                    <ListView x:Name="objectStylesListView" Grid.Row="1">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Width="32">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                      HorizontalAlignment="Center"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="Subcategory" Width="260"
                                                DisplayMemberBinding="{Binding Name}"/>
                                <GridViewColumn Header="Type" Width="120"
                                                DisplayMemberBinding="{Binding StyleType}"/>
                                <GridViewColumn Header="Status" Width="260"
                                                DisplayMemberBinding="{Binding Status}"/>
                            </GridView>
                        </ListView.View>
                    </ListView>

                    <WrapPanel Grid.Row="2" Margin="0 8 0 0">
                        <CheckBox x:Name="chkStylesIncludeModel"
                                  Content="Model"
                                  IsChecked="True"
                                  Checked="on_style_filter_changed"
                                  Unchecked="on_style_filter_changed"
                                  Margin="0 0 14 0"/>
                        <CheckBox x:Name="chkStylesIncludeAnnotation"
                                  Content="Annotation"
                                  IsChecked="True"
                                  Checked="on_style_filter_changed"
                                  Unchecked="on_style_filter_changed"
                                  Margin="0 0 14 0"/>
                        <CheckBox x:Name="chkStylesIncludeImports"
                                  Content="Imported"
                                  Checked="on_style_filter_changed"
                                  Unchecked="on_style_filter_changed"
                                  IsChecked="False"/>
                    </WrapPanel>
                </Grid>
            </TabItem>

        </TabControl>

        <!-- Row splitter for resizing -->
        <GridSplitter Grid.Row="1"
                      Height="6"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Center"
                      Background="#DDDDDD"
                      ShowsPreview="True"/>

        <!-- ============================================================ -->
        <!-- TARGET FAMILIES SECTION                                      -->
        <!-- ============================================================ -->
        <GroupBox Header="Target Families (currently open in Revit)"
                  Grid.Row="2" Margin="0 0 0 0">
            <Grid Margin="8 6 8 6">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Target toolbar -->
                <StackPanel Grid.Row="0" Orientation="Horizontal"
                            HorizontalAlignment="Right" Margin="0 0 0 4">
                    <Button Content="Select All"
                            Width="80" Height="26"
                            Margin="0 0 5 0"
                            Click="on_targets_select_all"/>
                    <Button Content="Select None"
                            Width="80" Height="26"
                            Click="on_targets_select_none"/>
                </StackPanel>

                <!-- Target ListView -->
                <ListView x:Name="targetListView"
                          Grid.Row="1"
                          SelectionMode="Extended">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Width="32">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay,
                                                  UpdateSourceTrigger=PropertyChanged}"
                                                  HorizontalAlignment="Center"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="Family Document" Width="500"
                                            DisplayMemberBinding="{Binding Title}"/>
                        </GridView>
                    </ListView.View>
                </ListView>

            </Grid>
        </GroupBox>

        <!-- ============================================================ -->
        <!-- FOOTER                                                       -->
        <!-- ============================================================ -->
        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0 10 0 0">
            <Button x:Name="okButton"
                    Content="Transfer"
                    Width="90" Height="30"
                    Margin="0 0 8 0"
                    IsDefault="True"
                    Click="on_ok"/>
            <Button x:Name="cancelButton"
                    Content="Cancel"
                    Width="80" Height="30"
                    IsCancel="True"
                    Click="on_cancel"/>
        </StackPanel>

    </Grid>
</Window>
