<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Xrev ReValue - Advanced Pattern Mapping" 
        Height="950" Width="1050"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize">
    <Window.Resources>
        <Style TargetType="GroupBox">
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Padding" Value="5"/>
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="Margin" Value="3"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Padding" Value="10,5"/>
        </Style>
    </Window.Resources>
    
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Mode Selection (Instance vs Type) -->
        <GroupBox Header="Mode" Grid.Row="0" Margin="5">
            <StackPanel Orientation="Horizontal" Margin="5">
                <RadioButton x:Name="radio_type" Content="Type Mode (default)" VerticalAlignment="Center" Margin="0,0,20,0" IsChecked="True"/>
                <RadioButton x:Name="radio_instance" Content="Instance Mode (for View, Wall, etc. instance data)" VerticalAlignment="Center"/>
            </StackPanel>
        </GroupBox>
        
        <!-- Delimiters Configuration -->
        <GroupBox Header="Tokenization Delimiters" Grid.Row="1" Margin="5">
            <DockPanel Margin="5">
                <TextBlock Text="Characters:" Width="80" DockPanel.Dock="Left" VerticalAlignment="Center"/>
                <TextBlock Text="(leave empty to use default: -_/,|)" Foreground="Gray" FontSize="9" DockPanel.Dock="Right" Margin="10,0,0,0" VerticalAlignment="Center"/>
                <TextBox x:Name="txt_delimiters" 
                         Height="24"
                         FontSize="11" FontFamily="Courier New"
                         VerticalAlignment="Center"
                         VerticalContentAlignment="Center"
                         Padding="3"/>
            </DockPanel>
        </GroupBox>
        
        <!-- Original Parameter Selection -->
        <GroupBox Header="Original Parameter (Source for Tokenization)" Grid.Row="2" Margin="5">
            <DockPanel Margin="5">
                <TextBlock Text="Select Parameter:" Width="150" DockPanel.Dock="Left" VerticalAlignment="Center"/>
                <TextBlock Text="(Leave empty to use Name)" Foreground="Gray" FontSize="9" DockPanel.Dock="Right" Margin="10,0,0,0" VerticalAlignment="Center"/>
                <ComboBox x:Name="combo_orig_param" Height="24" Margin="3,0,0,0"/>
            </DockPanel>
        </GroupBox>
        
        <!-- Parameters Selection for Pattern -->
        <GroupBox Header="Select Parameters for Pattern ({param1} through {param5})" Grid.Row="3" Margin="5">
            <Grid Margin="5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <TextBlock Text="Param 1:" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center"/>
                <ComboBox x:Name="combo_param1" Grid.Row="0" Grid.Column="1" Margin="3,0,10,0" Height="24"/>
                
                <TextBlock Text="Param 2:" Grid.Row="0" Grid.Column="2" VerticalAlignment="Center"/>
                <ComboBox x:Name="combo_param2" Grid.Row="0" Grid.Column="3" Margin="3,0,10,0" Height="24"/>
                
                <TextBlock Text="Param 3:" Grid.Row="0" Grid.Column="4" VerticalAlignment="Center"/>
                <ComboBox x:Name="combo_param3" Grid.Row="0" Grid.Column="5" Margin="3,0,0,0" Height="24"/>
                
                <TextBlock Text="Param 4:" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Margin="0,5,0,0"/>
                <ComboBox x:Name="combo_param4" Grid.Row="1" Grid.Column="1" Margin="3,5,10,0" Height="24"/>
                
                <TextBlock Text="Param 5:" Grid.Row="1" Grid.Column="2" VerticalAlignment="Center" Margin="0,5,0,0"/>
                <ComboBox x:Name="combo_param5" Grid.Row="1" Grid.Column="3" Margin="3,5,10,0" Height="24"/>
            </Grid>
        </GroupBox>
        
        <!-- Tokenization Display -->
        <GroupBox Header="Tokenization (from first selected item)" Grid.Row="4" Margin="5">
            <StackPanel Margin="5">
                <TextBox x:Name="txt_tokenization"
                         Height="40"
                         FontSize="10" FontFamily="Courier New"
                         IsReadOnly="True"
                         VerticalContentAlignment="Top"
                         TextWrapping="Wrap"
                         Background="WhiteSmoke"/>
            </StackPanel>
        </GroupBox>
        
        <!-- Pattern Configuration -->
        <GroupBox Header="Pattern Configuration" Grid.Row="5" Margin="5">
            <StackPanel Margin="5">
                <DockPanel Margin="0,0,0,10">
                    <TextBlock Text="Pattern:" FontSize="12" Width="100" DockPanel.Dock="Left" VerticalAlignment="Center"/>
                    <TextBox x:Name="txt_pattern"
                             Height="28"
                             FontSize="12" FontFamily="Courier New"
                             VerticalAlignment="Center"
                             VerticalContentAlignment="Center"
                             Padding="5"/>
                </DockPanel>

                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                    <CheckBox x:Name="chk_enable_counter"
                              Content="Enable Counter ({count} / {param6})"
                              VerticalAlignment="Center"/>
                </StackPanel>

                <DockPanel Margin="0,0,0,6">
                    <TextBlock Text="Start Value:" Width="100" DockPanel.Dock="Left" VerticalAlignment="Center"/>
                    <TextBox x:Name="txt_counter_start"
                             Height="24"
                             Width="160"
                             FontSize="11" FontFamily="Courier New"
                             VerticalAlignment="Center"
                             VerticalContentAlignment="Center"
                             Padding="3"/>
                </DockPanel>

                <DockPanel Margin="0,0,0,10">
                    <TextBlock Text="Increment:" Width="100" DockPanel.Dock="Left" VerticalAlignment="Center"/>
                    <TextBox x:Name="txt_counter_increment"
                             Height="24"
                             Width="160"
                             FontSize="11" FontFamily="Courier New"
                             VerticalAlignment="Center"
                             VerticalContentAlignment="Center"
                             Padding="3"/>
                </DockPanel>

                <Button x:Name="btn_syntax_examples"
                        Content="Syntax and Examples"
                        Width="180"
                        Height="30"
                        HorizontalAlignment="Left"
                        Background="#E67E22"
                        Foreground="White"
                        BorderBrush="#C96A12"
                        FontWeight="Bold"/>
            </StackPanel>
        </GroupBox>
        
        <!-- Preview Grid -->
        <GroupBox Header="Preview" Grid.Row="6" Margin="5">
            <DataGrid x:Name="preview_grid" 
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      GridLinesVisibility="All"
                      AlternatingRowBackground="WhiteSmoke"
                      Margin="0,5,0,0">
                <DataGrid.CellStyle>
                    <Style TargetType="DataGridCell">
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="ToolTip" Value="{Binding tooltip}"/>
                    </Style>
                </DataGrid.CellStyle>
                <DataGrid.Columns>
                    <DataGridCheckBoxColumn Header="Final" Binding="{Binding final}" Width="50"/>
                    <DataGridTextColumn Header="Current Name" Binding="{Binding CurrentName}" Width="*" IsReadOnly="True"/>
                    <DataGridTextColumn Header="New Name" Binding="{Binding NewName}" Width="*" IsReadOnly="True">
                        <DataGridTextColumn.CellStyle>
                            <Style TargetType="DataGridCell">
                                <Setter Property="ToolTip" Value="{Binding tooltip}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding final}" Value="True">
                                        <Setter Property="Background" Value="LightGreen"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGridTextColumn.CellStyle>
                    </DataGridTextColumn>
                </DataGrid.Columns>
            </DataGrid>
        </GroupBox>
        
        <!-- Buttons -->
        <StackPanel Grid.Row="7" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="btn_apply" Content="Apply Re-Value" Width="140"/>
            <Button x:Name="btn_cancel" Content="Cancel" Width="80"/>
        </StackPanel>
    </Grid>
</Window>
