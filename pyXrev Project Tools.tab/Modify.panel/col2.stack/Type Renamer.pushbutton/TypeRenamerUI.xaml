<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Rename Family Types" 
        Height="700" Width="900"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize">
    <Window.Resources>
        <Style TargetType="GroupBox">
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Padding" Value="5"/>
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="Margin" Value="3"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Padding" Value="10,5"/>
        </Style>
    </Window.Resources>
    
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Parameters Selection -->
        <GroupBox Header="Select Parameters (Text, Length, Area, Angle, Integer)" Grid.Row="0" Margin="5">
            <Grid Margin="5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <TextBlock Text="Param 1:" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center"/>
                <ComboBox x:Name="combo_param1" Grid.Row="0" Grid.Column="1" Margin="3,0,10,0" Height="24"/>
                
                <TextBlock Text="Param 2:" Grid.Row="0" Grid.Column="2" VerticalAlignment="Center"/>
                <ComboBox x:Name="combo_param2" Grid.Row="0" Grid.Column="3" Margin="3,0,10,0" Height="24"/>
                
                <TextBlock Text="Param 3:" Grid.Row="0" Grid.Column="4" VerticalAlignment="Center"/>
                <ComboBox x:Name="combo_param3" Grid.Row="0" Grid.Column="5" Margin="3,0,0,0" Height="24"/>
                
                <TextBlock Text="Param 4:" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Margin="0,5,0,0"/>
                <ComboBox x:Name="combo_param4" Grid.Row="1" Grid.Column="1" Margin="3,5,10,0" Height="24"/>
                
                <TextBlock Text="Param 5:" Grid.Row="1" Grid.Column="2" VerticalAlignment="Center" Margin="0,5,0,0"/>
                <ComboBox x:Name="combo_param5" Grid.Row="1" Grid.Column="3" Margin="3,5,10,0" Height="24"/>
            </Grid>
        </GroupBox>
        
        <!-- Pattern Configuration -->
        <GroupBox Header="Pattern Configuration" Grid.Row="1" Margin="5">
            <StackPanel Margin="5">
                <DockPanel Margin="0,0,0,10">
                    <TextBlock Text="Original Pattern:" FontSize="12" Width="120" DockPanel.Dock="Left" VerticalAlignment="Center"/>
                    <TextBox x:Name="txt_original_pattern"
                             Height="24"
                             FontSize="12" FontFamily="Courier New"
                             VerticalAlignment="Center"
                             VerticalContentAlignment="Center"/>
                </DockPanel>
                
                <DockPanel Margin="0,0,0,10">
                    <TextBlock Text="New Pattern:" FontSize="12" Width="120" DockPanel.Dock="Left" VerticalAlignment="Center"/>
                    <TextBox x:Name="txt_new_pattern"
                             Height="24"
                             FontSize="12" FontFamily="Courier New"
                             VerticalAlignment="Center"
                             VerticalContentAlignment="Center"/>
                </DockPanel>
                
                <TextBlock Text="ORIGINAL: Use template syntax like {val1}-{val2}-{val3}. Matches and extracts the parts." 
                           Margin="0,5,0,5" TextWrapping="Wrap" FontSize="10" Foreground="DarkRed" FontWeight="Bold"/>
                <TextBlock Text="NEW: Use {val1}, {val2}, {val3}... for extracted parts. Use {param1}, {param2}... for selected parameters." 
                           Margin="0,0,0,0" TextWrapping="Wrap" FontSize="10" Foreground="Gray"/>
            </StackPanel>
        </GroupBox>
        
        <!-- Help Text -->
        <TextBlock Grid.Row="2" Margin="5" TextWrapping="Wrap" FontSize="10" Foreground="DarkBlue"
                   Text="Check Final to lock a type's new name and prevent it from changing when you update the pattern."/>
        
        <!-- Preview Grid -->
        <GroupBox Header="Preview" Grid.Row="3" Margin="5">
            <DataGrid x:Name="preview_grid" 
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      GridLinesVisibility="All"
                      AlternatingRowBackground="WhiteSmoke"
                      Margin="0,5,0,0">
                <DataGrid.CellStyle>
                    <Style TargetType="DataGridCell">
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="ToolTip" Value="{Binding tooltip}"/>
                    </Style>
                </DataGrid.CellStyle>
                <DataGrid.Columns>
                    <DataGridCheckBoxColumn Header="Final" Binding="{Binding final}" Width="50"/>
                    <DataGridTextColumn Header="Type Name" Binding="{Binding CurrentName}" Width="*" IsReadOnly="True"/>
                    <DataGridTextColumn Header="New Name" Binding="{Binding NewName}" Width="*" IsReadOnly="True">
                        <DataGridTextColumn.CellStyle>
                            <Style TargetType="DataGridCell">
                                <Setter Property="ToolTip" Value="{Binding tooltip}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding final}" Value="True">
                                        <Setter Property="Background" Value="LightGreen"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGridTextColumn.CellStyle>
                    </DataGridTextColumn>
                </DataGrid.Columns>
            </DataGrid>
        </GroupBox>
        
        <!-- Buttons -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="btn_apply" Content="Apply Rename" Width="120"/>
            <Button x:Name="btn_cancel" Content="Cancel" Width="80"/>
        </StackPanel>
    </Grid>
</Window>
