<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Split by Level - Select Levels"
        Height="380" Width="300"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- Header -->
            <RowDefinition Height="*"/>      <!-- Level list + select buttons -->
            <RowDefinition Height="Auto"/>   <!-- OK/Cancel -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0"
                   Text="Select levels to split at:"
                   Margin="0,0,0,8"/>

        <!-- Level list area -->
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>      <!-- Level list -->
                <RowDefinition Height="Auto"/>   <!-- Select All / None -->
            </Grid.RowDefinitions>

            <!-- Level list -->
            <ListBox x:Name="lstLevels"
                     Grid.Row="0"
                     Margin="0,0,0,8"/>

            <!-- Select All / Select None -->
            <StackPanel Grid.Row="1"
                        Orientation="Horizontal"
                        HorizontalAlignment="Left"
                        Margin="0,0,0,5">
                <Button Content="Select All"
                        Width="90" Height="30"
                        Margin="0,0,5,0"
                        Click="on_select_all"/>

                <Button Content="Select None"
                        Width="90" Height="30"
                        Click="on_select_none"/>
            </StackPanel>
        </Grid>

        <!-- OK / Cancel -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Content="OK"
                    Width="80" Height="30"
                    Margin="0,0,5,0"
                    Click="on_ok"/>

            <Button Content="Cancel"
                    Width="80" Height="30"
                    Click="on_cancel"/>
        </StackPanel>

    </Grid>
</Window>