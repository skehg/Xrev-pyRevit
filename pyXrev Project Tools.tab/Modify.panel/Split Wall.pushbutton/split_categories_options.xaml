<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Split by Level - Categories &amp; Options"
        Height="220" Width="320"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- Categories + offset -->
            <RowDefinition Height="*"/>      <!-- Flexible spacer -->
            <RowDefinition Height="Auto"/>   <!-- Buttons -->
        </Grid.RowDefinitions>

        <!-- Main content -->
        <StackPanel Grid.Row="0">
            <TextBlock Text="Select categories to split:" Margin="0,0,0,5"/>

            <CheckBox x:Name="chkWalls" Content="Walls" IsChecked="True" Margin="0,0,0,2"/>
            <CheckBox x:Name="chkColumns" Content="Columns" IsChecked="True" Margin="0,0,0,2"/>
            <CheckBox x:Name="chkStrColumns" Content="Structural Columns" IsChecked="True" Margin="0,0,0,10"/>

            <StackPanel Orientation="Horizontal" Margin="5">
                <TextBlock Text="Split Offset (mm):" VerticalAlignment="Center" Width="120"/>
                <TextBox Name="txtOffset" Width="60" Text="0"/>
            </StackPanel>
        </StackPanel>

        <!-- Buttons pinned to bottom -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Content="OK" Width="70" Height="30" Margin="0,0,5,0" Click="on_ok"/>
            <Button Content="Cancel" Width="70" Height="30" Click="on_cancel"/>
        </StackPanel>

    </Grid>
</Window>