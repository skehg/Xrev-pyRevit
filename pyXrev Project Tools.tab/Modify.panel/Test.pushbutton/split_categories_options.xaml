<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Split by Level - Categories &amp; Options"
        Height="260" Width="320" WindowStartupLocation="CenterScreen">
    <StackPanel Margin="10">

        <TextBlock Text="Select categories to split:" Margin="0,0,0,5"/>

        <CheckBox x:Name="chkWalls" Content="Walls" IsChecked="True" Margin="0,0,0,2"/>
        <CheckBox x:Name="chkColumns" Content="Columns" IsChecked="True" Margin="0,0,0,2"/>
        <CheckBox x:Name="chkStrColumns" Content="Structural Columns" IsChecked="True" Margin="0,0,0,10"/>

        <StackPanel Orientation="Horizontal" Margin="5">
            <TextBlock Text="Split Offset (mm):" VerticalAlignment="Center" Width="120"/>
            <TextBox Name="txtOffset" Width="60" Text="0"/>
        </StackPanel>

        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
            <Button Content="Select All" Width="80" Margin="0,0,5,0" Click="on_select_all"/>
            <Button Content="Select None" Width="80" Click="on_select_none"/>
        </StackPanel>

        <Separator Margin="0,0,0,10"/>

        <CheckBox x:Name="chkLock" Content="Lock resulting segments" IsChecked="False" Margin="0,0,0,10"/>

        <TextBlock Text="Wall lock reference:" Margin="0,0,0,5"/>
        <ComboBox x:Name="cmbRefMode" SelectedIndex="0" Margin="0,0,0,10">
            <ComboBoxItem Content="Centerline"/>
            <ComboBoxItem Content="Core Face"/>
            <ComboBoxItem Content="Wall Face"/>
        </ComboBox>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="OK" Width="70" Margin="0,0,5,0" Click="on_ok"/>
            <Button Content="Cancel" Width="70" Click="on_cancel"/>
        </StackPanel>

    </StackPanel>
</Window>